generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// permissions: lista sekcji do których user ma dostęp (np. ['przeroby', 'clients']).
// Identyfikatory zdefiniowane w lib/permissions.ts (ALL_PERMISSIONS).
// Admin (NEXT_PUBLIC_ADMIN_EMAIL) ma override — jego permissions ignorowane, zawsze ma wszystko.
// Default [] — bezpieczny default; nowy user nie ma dostępu nigdzie dopóki admin nie nada.
// Istniejący userzy też dostaną [] po `prisma db push` — admin musi w /settings nadać im sekcje.
//
// Pola personalizacji (preferredName, interests, customInterests):
//  - preferredName — wyświetlane w powitaniu w dashboardzie (fallback: pierwsze słowo z name / email)
//  - interests — predefiniowane tematy newsów dnia (IDs z lib/news-feed.ts: tech, world, business, ...)
//  - customInterests — własne tematy free-form (max 50 znaków każdy, max 5 sztuk), fetch przez Google News search
//
// Endpoint /api/dashboard/widget czyta interests z DB po userId — zmiana działa natychmiast (bez re-login).
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String?
  preferredName    String?
  interests        String[]  @default([])
  customInterests  String[]  @default([])
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  permissions      String[]  @default([])
  createdAt        DateTime  @default(now())

  // Moduł Finanse
  createdInvoices            PurchaseInvoice[]           @relation("InvoiceCreator")
  createdPayments            PurchaseInvoicePayment[]    @relation("PaymentCreator")
  invoiceApprovals           PurchaseInvoiceApproval[]
  uploadedInvoiceAttachments PurchaseInvoiceAttachment[]
}

// status: ZAPYTANIE | OFERTA | REZERWACJA | UMOWA | ODBIOR
model Client {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String?
  phone      String?
  phone2     String?
  pesel      String?
  nip        String?
  idNumber   String?
  fatherName String?
  motherName String?
  address    String?
  city       String?
  zipCode    String?
  status     String   @default("ZAPYTANIE")
  source     String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  activities      Activity[]
  clientUnits     ClientUnit[]
  serviceRequests ServiceRequest[]
  contracts       Contract[]
  contractClients ContractClient[]
  offers          Offer[]
}

// type: MIESZKALNY | USLUGOWY | PARKING | GARAZ | KOMORKA
// status: WOLNY | ZAREZERWOWANY | SPRZEDANY | NIEDOSTEPNY
// reservationType: null | MIEKKA | REZERWACJA
model Unit {
  id                   String    @id @default(cuid())
  number               String    @unique
  type                 String
  area                 Float
  pricePerSqmNet       Float     @default(0)
  pricePerSqmGross     Float     @default(0)
  priceNet             Float
  priceGross           Float
  vatRate              Int       @default(8)
  floor                Int?
  rooms                Int?
  building             String?
  description          String?
  status               String    @default("WOLNY")
  floorPlanUrl         String?
  reservationType      String?
  reservationExpiresAt DateTime?
  reservedById         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  clientUnits      ClientUnit[]
  serviceRequests  ServiceRequest[]
  contractUnits    ContractUnit[]
  offerItems       OfferItem[]
  images           UnitImage[]
  creativeSettings UnitCreativeSettings?
}

// Zapamietane ustawienia generatora kreacji Meta Ads per lokal — zeby user
// nie ustawial ceny/CTA/hasla/tla za kazdym razem. Patrz docs/meta-ads-decyzje.md.
// backgrounds: JSON map { feed_square: "/uploads/...", feed_portrait: ..., story: ..., landscape: ... }
//   pusta wartosc dla formatu = auto-wybor tla.
model UnitCreativeSettings {
  id          String   @id @default(cuid())
  unitId      String   @unique
  priceMode   String   @default("FROM")
  ctaText     String   @default("Zobacz szczegóły")
  headline    String   @default("")
  backgrounds String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

// Galeria zdjec/wizualizacji per lokal. Uzywana do generowania kreacji
// reklamowych Meta Ads (FB/IG) — patrz docs/meta-ads-decyzje.md.
// floorPlanUrl na modelu Unit zostaje osobno (karta PDF mieszkania).
// isPrimary: zdjecie glowne (tlo kreacji reklamowej, miniaturka w listach).
// position: kolejnosc w galerii (drag-reorder w UI).
// kind: kategoria zdjecia (RZUT_3D | DOLL_HOUSE | WNETRZE | WIDOK_Z_OKNA | INNE) —
//   patrz UNIT_IMAGE_KIND_LABELS w lib/types.ts. Uzywana przez generator kreacji
//   do wyboru zdjecia per format (np. Story 9:16 = WNETRZE pionowe).
model UnitImage {
  id        String   @id @default(cuid())
  unitId    String
  url       String
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  kind      String   @default("INNE")
  createdAt DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, position])
}

// Wizualizacje wspolne dla calej inwestycji (Nova Staffa) — nie per-lokal,
// reuse'owane przez generator kreacji Meta Ads dla wszystkich lokali.
// Zarzadzane w /settings (admin only). Folder uploadow: public/uploads/investment/.
// kind: ZEWNETRZNE | WEWNETRZNE | OTOCZENIE | INNE — patrz INVESTMENT_IMAGE_KIND_LABELS.
model InvestmentImage {
  id        String   @id @default(cuid())
  url       String
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  kind      String   @default("INNE")
  createdAt DateTime @default(now())

  @@index([position])
}

model ClientUnit {
  id         String   @id @default(cuid())
  clientId   String
  unitId     String
  assignedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([clientId, unitId])
}

// type: NOTATKA | TELEFON | EMAIL | SPOTKANIE | DOKUMENT
model Activity {
  id        String   @id @default(cuid())
  clientId  String
  type      String   @default("NOTATKA")
  title     String
  content   String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// status: ZGLOSZONO | W_TOKU | ZAKONCZONE
// priority: NISKA | SREDNIA | WYSOKA
model ServiceRequest {
  id          String    @id @default(cuid())
  clientId    String
  unitId      String?
  title       String
  description String?
  status      String    @default("ZGLOSZONO")
  priority    String    @default("SREDNIA")
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  unit   Unit?  @relation(fields: [unitId], references: [id], onDelete: SetNull)
}

model CalendarToken {
  id           String    @id @default(cuid())
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// type: REZERWACYJNA | DEWELOPERSKA | PRZENIESIENIA
// status: W_PRZYGOTOWANIU | PODPISANA | ROZWIAZANA | ANULOWANA
model Contract {
  id              String    @id @default(cuid())
  number          String    @unique
  type            String
  status          String    @default("W_PRZYGOTOWANIU")
  investmentName  String    @default("Inwestycja")
  clientId        String
  introducedAt    DateTime  @default(now())
  plannedSignDate DateTime?
  signedAt        DateTime?
  form            String?
  reservationFee  Float?
  discount        Float?
  valueNet        Float?
  valueGross      Float?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contractClients ContractClient[]
  contractUnits   ContractUnit[]
  attachments     ContractAttachment[]
  history         ContractHistory[]
}

model ContractClient {
  id         String @id @default(cuid())
  contractId String
  clientId   String
  position   Int    @default(1)

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([contractId, clientId])
}

model ContractUnit {
  id         String @id @default(cuid())
  contractId String
  unitId     String

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([contractId, unitId])
}

// =============================================================
// MODUŁ: OBMIARY Z RYSUNKÓW (DXF/PDF)
// =============================================================

// Projekt rysunkowy (np. "Budynek A – Kondygnacja 0")
model DrawingProject {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("KONSTRUKCYJNY") // ARCHITEKTONICZNY | KONSTRUKCYJNY | INSTALACYJNY
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  drawings Drawing[]
}

// Rysunek (plik DXF/PDF/DWG)
model Drawing {
  id             String   @id @default(cuid())
  projectId      String?
  name           String
  originalName   String
  fileType       String // DXF | PDF | DWG | IMAGE
  filePath       String
  fileSize       Int?
  scaleLabel     String   @default("1:50") // np. "1:50", "1:100"
  pixelsPerMeter Float? // kalibracja: ile px = 1m
  pageWidth      Int?
  pageHeight     Int?
  status         String   @default("UPLOADED") // UPLOADED | READY | ERROR
  aiAnalyzed     Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project  DrawingProject?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  elements DrawingElement[]
}

// Typ elementu: konstrukcyjny lub architektoniczny
// KONSTRUKCYJNY: STROP | PODCIAG | SLUP | WIENIEC | SCIANA_ZB | LAW_FUND | STOP_FUND | NADPROZ
// ARCHITEKTONICZNY: ELEWACJA | TYNK_ZEW | TYNK_WEW | POSADZKA | DACH | OKNO | DRZWI | OCIEPLENIE
model DrawingElement {
  id         String   @id @default(cuid())
  drawingId  String
  type       String // patrz komentarz wyżej
  label      String // np. "Strop nad parterem", "Słup S-01"
  floor      String? // "PIWNICA" | "PARTER" | "PIETRO_1" | ...
  geometry   String // JSON: [{x,y},...] punkty w px na canvas
  // Przeliczone wymiary (w metrach)
  lengthM    Float?
  widthM     Float?
  heightM    Float?
  perimeterM Float?
  areaM2     Float?
  volumeM3   Float?
  // Szacunki materiałowe
  concreteM3 Float? // beton wg normy
  steelKg    Float? // stal wg wskaźnika kg/m³ lub kg/m²
  // Rozliczenie
  unit       String   @default("M2") // M2 | M3 | MB | SZT | KG | T
  qty        Float    @default(0)
  notes      String?
  verified   Boolean  @default(false)
  source     String   @default("MANUAL") // MANUAL | AI | DXF_AUTO
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  drawing Drawing @relation(fields: [drawingId], references: [id], onDelete: Cascade)
}

model ContractAttachment {
  id         String   @id @default(cuid())
  contractId String
  filename   String
  url        String
  size       Int?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model ContractHistory {
  id         String   @id @default(cuid())
  contractId String
  event      String
  details    String?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

// =============================================================
// MODUŁ: PRZEROBY (kontroling protokołów przerobowych)
// =============================================================

// Podwykonawca — firma wykonawcza
model Subcontractor {
  id          String   @id @default(cuid())
  name        String
  nip         String?
  regon       String?
  address     String?
  city        String?
  zipCode     String?
  contactName String?
  email       String?
  phone       String?
  bankAccount String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts SubContract[]
  protocols Protocol[]
}

// Umowa z podwykonawcą — kosztorys umowny w pozycjach (ContractWorkItem)
model SubContract {
  id              String    @id @default(cuid())
  subcontractorId String
  number          String?
  title           String
  scopeText       String? // np. "Roboty konstrukcyjne"
  signedAt        DateTime?
  startDate       DateTime?
  endDate         DateTime?
  // valueNet — wyliczana z protokołów: Σ(ContractWorkItem.plannedQty × unitPrice).
  // Obejmuje TYLKO pozycje które weszły do dotychczasowych protokołów — czyli
  // zafakturowany zakres, NIE cała umowa. Nadpisywana przy każdym imporcie.
  valueNet        Float?
  // agreedValueNet — umowna wartość netto z dokumentu umowy (CAŁY zakres robót:
  // wszystkie kondygnacje + dach). Wpisywana ręcznie w UI. Importer jej NIE dotyka.
  // To prawidłowy mianownik wskaźnika "% kontraktu" w widoku protokołu.
  agreedValueNet  Float?
  retentionPct    Float     @default(0)
  status          String    @default("AKTYWNA") // AKTYWNA | ZAKONCZONA | ANULOWANA
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subcontractor Subcontractor      @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  workItems     ContractWorkItem[]
  protocols     Protocol[]
}

// Pozycja umowna (kosztorys) — jedna linia w protokole przerobowym.
// Np. "Zaszalowanie i zabetonowanie ław fundamentowych" m³ 540 zł/m³, plan 76,55.
model ContractWorkItem {
  id          String   @id @default(cuid())
  contractId  String
  section     String? // "FUNDAMENTY", "PARTER", "I Piętro" (kondygnacja)
  position    Int      @default(0) // numer w sekcji
  globalOrder Int      @default(0) // globalny porządek w umowie
  name        String // opis prac
  unit        String // m3 | m2 | T | kpl | mb | stopni | kg
  unitPrice   Float    @default(0)
  plannedQty  Float    @default(0) // ilość planowana
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contract      SubContract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  protocolItems ProtocolItem[]

  @@index([contractId, globalOrder])
}

// Zakres robót — branża/etap (np. Konstrukcja żelbetowa, Prace murarskie, Tynki...)
// Każdy zakres ma własny obmiar i własne kategorie.
model WorkScope {
  id          String   @id @default(cuid())
  name        String   @unique // "Konstrukcja żelbetowa"
  slug        String   @unique // "konstrukcja-zelbetowa"
  order       Int      @default(0)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  categories     WorkCategory[]
  floorSummaries FloorSummary[]
}

// Kategoria robót = jeden arkusz Excela (Fundamenty, Piony 0, Belki nad 0...)
// należy do konkretnego zakresu (WorkScope).
model WorkCategory {
  id          String   @id @default(cuid())
  scopeId     String
  name        String
  slug        String
  order       Int      @default(0)
  primaryUnit String   @default("M3") // M3 | M2 | SZT
  description String?
  createdAt   DateTime @default(now())

  scope WorkScope  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  items WorkItem[]

  @@unique([scopeId, slug])
}

// Powiązanie odwrotne — WorkScope ma summaries
// (Prisma wymaga relacji w obie strony)

// Podsumowanie kondygnacji — agregat kierownika łączący obmiar inżynierski
// z pozycjami umownymi (i protokołami). Per kondygnacja: PARTER, I_PIETRO, ...
model FloorSummary {
  id         String   @id @default(cuid())
  scopeId    String // np. konstrukcja-zelbetowa
  floor      String // "PARTER", "I_PIETRO", "II_PIETRO", "DACH"
  source     String? // ścieżka pliku xlsx
  importedAt DateTime @default(now())
  notes      String?

  scope WorkScope          @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  items FloorSummaryItem[]

  @@unique([scopeId, floor])
}

// Pojedyncza pozycja w podsumowaniu kondygnacji (np. „Zaszalowanie ścian parteru").
// matchMode określa czy porównanie z obmiarem inżynierskim jest automatyczne czy ręczne.
//   AUTO_OK            — reguła mapowania działa, wartość liczona z obmiaru
//   MANUAL_FLOOR_SPLIT — element rozpięty na kilku kondygnacjach (ściany, słupy, trzpienie)
//   MANUAL_DIFF_UNIT   — różna jednostka (np. schody kpl vs szt biegów)
//   MANUAL_OUT_OF_SCOPE— poza zakresem ŻB (murowanie, łączniki)
//   MANUAL_NOT_FOUND   — pozycja nieobecna w obmiarze inżynierskim (np. daszki)
//   MANUAL_OVERRIDE    — użytkownik świadomie nadpisał wartość
//   MANUAL_ADDED       — pozycja dodana ręcznie przez usera w UI (poza pozycjami z buildPositionsForFloor); zachowywane przy reimporcie
model FloorSummaryItem {
  id          String @id @default(cuid())
  summaryId   String
  position    Int    @default(0)
  name        String
  unit        String // m3, m2, mb, kpl, szt, T, kg
  laborQty    Float  @default(0) // "Robocizny" — to co rozliczane w protokole
  concreteVol Float  @default(0) // m³ betonu C25/30
  rebarMass   Float  @default(0) // kg zbrojenia

  matchMode             String    @default("AUTO_OK")
  matchReason           String? // automatyczny opis dlaczego nie matchuje
  mappingRule           String? // JSON: { categoryName, elementType?, floorName?, namePattern? }
  manualValue           Float? // ręczna wartość Marafu (override autoValue z reguły)
  manualNote            String? // komentarz do manualValue
  konradManualValue     Float? // ręczna wartość Konrada (gdy nie ma detalu w xlsx) — wpisuje kierownik lub admin
  konradManualReason    String? // uzasadnienie wartości Konrada — WYMAGANE gdy |Δ| > 5% vs Maraf
  // DEPRECATED — zastąpione przez investorApproved*. Pola zostają w schemie/bazie żeby
  // nie tracić historycznych danych (kto co kiedy kierowniczo zaakceptował). Nie używane w UI.
  accepted              Boolean   @default(false)
  acceptedAt            DateTime?
  acceptedNote          String?
  // Akceptacja przez Inwestora (admin) — warunek konieczny przejścia pozycji do protokołu.
  // investorApprovedValue = snapshot wartości kierownika w momencie akceptacji (do auditingu —
  // jeśli wartość się zmieni po akceptacji, widać że potrzeba reakceptacji).
  investorApproved      Boolean   @default(false)
  investorApprovedBy    String?
  investorApprovedAt    DateTime?
  investorApprovedNote  String?
  investorApprovedValue Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  summary FloorSummary              @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  history FloorSummaryItemHistory[]

  @@index([summaryId])
}

// Historia zmian per pozycja podsumowania — auditing dla ręcznych decyzji kierownika
// (akceptacja różnicy, wpis ręcznej wartości Marafu/Konrada, komentarze).
model FloorSummaryItemHistory {
  id        String   @id @default(cuid())
  itemId    String
  action    String // ACCEPT | UNACCEPT | SET_MANUAL_VALUE | CLEAR_MANUAL_VALUE | SET_KONRAD_VALUE | CLEAR_KONRAD_VALUE | INVESTOR_APPROVE | INVESTOR_UNAPPROVE | ITEM_ADDED | EDIT_NOTE | REIMPORT
  oldValue  String? // poprzednia wartość (JSON serialized)
  newValue  String? // nowa wartość (JSON serialized)
  note      String? // komentarz / uzasadnienie z formularza
  userEmail String? // email użytkownika z sesji
  createdAt DateTime @default(now())

  item FloorSummaryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
}

// Pozycja obmiaru (master, niezmienna po imporcie)
// primaryUnit dziedziczy z kategorii ale może być nadpisana per pozycja
model WorkItem {
  id          String  @id @default(cuid())
  categoryId  String
  floor       String? // "Kondygnacja 0", "+1", "Dach"
  elementType String? // "Ławy fund.", "Słupy 0", "Belki stropu K0"
  name        String // "Łf-01", "S-P.01"
  count       Int? // liczba sztuk
  lengthM     Float?
  widthM      Float?
  heightM     Float?
  areaM2      Float?
  volumeM3    Float?
  primaryUnit String  @default("M3") // którą wartością rozliczamy
  primaryQty  Float   @default(0) // wartość w primaryUnit (np. V dla M3, A dla M2)
  notes       String?
  sourceRow   Int? // numer wiersza w Excelu (debug)

  category WorkCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

// Protokół przerobowy — okres rozliczeniowy (od/do), powiązany z umową
// status: SZKIC | ZATWIERDZONY | ZAFAKTUROWANY | ANULOWANY
model Protocol {
  id              String    @id @default(cuid())
  number          String?
  subcontractorId String
  contractId      String
  periodFrom      DateTime
  periodTo        DateTime
  // Cache miesiąca/roku do sortowania i list (= miesiąc/rok periodTo)
  periodYear      Int
  periodMonth     Int
  status          String    @default("SZKIC")
  issuedAt        DateTime  @default(now())
  approvedAt      DateTime?
  invoicedAt      DateTime?
  notes           String?
  totalNet        Float     @default(0) // suma w tym okresie
  retentionAmount Float     @default(0)
  payableNet      Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subcontractor Subcontractor  @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  contract      SubContract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  items         ProtocolItem[]
}

// Pozycja w protokole — odnosi się do pozycji umownej (ContractWorkItem).
// qty = ilość wykonana w TYM okresie (delta).
model ProtocolItem {
  id                 String  @id @default(cuid())
  protocolId         String
  contractWorkItemId String
  qty                Float   @default(0)
  unit               String  @default("m3")
  unitPrice          Float   @default(0)
  amountNet          Float   @default(0)
  note               String?
  // Ręczne porównanie z obmiarem Maraf — gdy auto-dopasowanie (lib/protokol-maraf-match.ts)
  // jest niepewne, błędne lub brakuje reguły, user wpisuje wartość ręcznie.
  // Wpisana wartość NADPISUJE auto-match w kolumnie "Maraf (obmiar)" w UI protokołu.
  // marafManualValue jest w jednostce pozycji protokołu (ProtocolItem.unit).
  marafManualValue   Float?
  marafManualNote    String?

  protocol         Protocol         @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  contractWorkItem ContractWorkItem @relation(fields: [contractWorkItemId], references: [id], onDelete: Restrict)

  @@index([protocolId])
  @@index([contractWorkItemId])
}

// =============================================================
// MODUŁ: KALKULATOR OFERTY (CRM)
// =============================================================
// status: SZKIC | WYSLANA | ZAAKCEPTOWANA | ODRZUCONA | ANULOWANA
model Offer {
  id                 String    @id @default(cuid())
  number             String?   @unique
  clientId           String?
  title              String?
  validUntil         DateTime?
  status             String    @default("SZKIC")
  notes              String?
  // Sumy snapshot (przeliczane przy każdej zmianie pozycji)
  subtotalNet        Float     @default(0) // suma netto przed rabatem
  subtotalGross      Float     @default(0) // suma brutto przed rabatem
  totalDiscountNet   Float     @default(0)
  totalDiscountGross Float     @default(0)
  totalNet           Float     @default(0) // po rabacie
  totalGross         Float     @default(0) // po rabacie
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items  OfferItem[]
}

// =============================================================
// MODUŁ: FINANSE (faktury zakupowe + workflow akceptacji)
// =============================================================
// Zastępuje plik PŁATNOŚCI 2026.xlsx (siostra Marta wprowadza, tata Bohdan
// akceptuje kolorem). Patrz docs/finanse-rozpoczecie.md.
//
// Workflow: WPROWADZONA → DO_ZATWIERDZENIA → ZATWIERDZONA/ODRZUCONA → OPLACONA
// Permissions: 'finanse' (czyta+wprowadza), 'finanse.approve' (zatwierdza).

// category: DOSTAWCA | BANK | LEASING | URZAD | PODWYKONAWCA | INNE
model Vendor {
  id        String   @id @default(cuid())
  name      String   @unique
  shortCode String?
  nip       String?
  category  String   @default("DOSTAWCA")
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices PurchaseInvoice[]
}

// status: WPROWADZONA | DO_ZATWIERDZENIA | ZATWIERDZONA | ZAPLANOWANA | OPLACONA | CZESCIOWO_OPLACONA | ODRZUCONA | ANULOWANA
//
// Workflow:
//  WPROWADZONA       — Marta wpisała, nie wysłała jeszcze do akceptacji
//  DO_ZATWIERDZENIA  — w inboksie Bohdana
//  ZATWIERDZONA      — Bohdan zaakceptował, Marta może płacić
//  ZAPLANOWANA       — Marta zleciła przelew, ale nie wykonano (opcjonalne)
//  OPLACONA          — Σ(payments.amount) >= amountGross
//  CZESCIOWO_OPLACONA — 0 < Σ(payments) < amountGross
//  ODRZUCONA         — Bohdan odrzucił (komentarz wymagany); Marta poprawia → wraca do WPROWADZONA
//  ANULOWANA         — faktura skorygowana, anulowana po stronie dostawcy
//
// importedFromColor — jaki kolor wiersza był w xlsx przy imporcie (do auditu mapowania).
// subVendor — dla zakładek STAFFA/MURARZ gdzie w kol A jest subkontrahent (PATRIMEX, AL-BUD).
model PurchaseInvoice {
  id                String    @id @default(cuid())
  number            String // numer faktury od dostawcy (FV)
  vendorId          String
  subVendor         String?
  issueDate         DateTime
  dueDate           DateTime?
  vatRate           Float // 0.23, 0.08, 0.05
  amountGross       Float
  amountNet         Float
  amountVat         Float
  currency          String    @default("PLN")
  status            String    @default("WPROWADZONA")
  description       String? // np. "murowanie ścian I piętro" (z MURARZ.M)
  notes             String?
  // Pola dodatkowe — w większości faktur puste, używane głównie dla MURARZ
  deposit           Float?
  buildingCosts     Float?
  electricity       Float?
  // Pola powiązań przyszłościowych (Faza 2)
  investmentId      String? // przyszłość: powiązanie z inwestycją
  saldeoId          String? // ID faktury w Saldeo (po integracji w Fazie 2)
  // Audit
  importedFromColor String? // np. "FFE6B8AF" — z którego koloru w xlsx
  importSheet       String? // np. "STAFFA" — z której zakładki
  importRow         Int? // numer wiersza w xlsx (debug)
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  vendor      Vendor                      @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  createdBy   User?                       @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  payments    PurchaseInvoicePayment[]
  approvals   PurchaseInvoiceApproval[]
  attachments PurchaseInvoiceAttachment[]

  @@unique([vendorId, number])
  @@index([status, dueDate])
  @@index([vendorId, issueDate])
  @@index([dueDate])
}

// Bookkeeping płatności — 1 faktura = N płatności (wspiera częściowe).
// Płatności NIE wymagają osobnej akceptacji (decyzja 2026-05-17 — Bohdan
// akceptuje całą fakturę raz, Marta dowolnie wiele płatności do niej).
model PurchaseInvoicePayment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Float
  paidAt      DateTime
  bankAccount String? // skrót banku: ING, Santander, mBank...
  reference   String? // tytuł przelewu
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  invoice   PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("PaymentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([paidAt])
}

// action: SUBMITTED | APPROVED | REJECTED | RESET | EDITED
// Audit trail decyzji akceptacyjnych. SUBMITTED = Marta wysłała do akceptacji.
// APPROVED/REJECTED = decyzja Bohdana. RESET = cofnięcie do WPROWADZONA (np. po edycji).
model PurchaseInvoiceApproval {
  id        String   @id @default(cuid())
  invoiceId String
  action    String
  comment   String?
  userId    String?
  userEmail String? // snapshot na wypadek usunięcia usera
  createdAt DateTime @default(now())

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([invoiceId, createdAt])
}

model PurchaseInvoiceAttachment {
  id           String   @id @default(cuid())
  invoiceId    String
  filename     String
  url          String // ścieżka pod /uploads/finanse/...
  mimeType     String
  size         Int?
  uploadedById String?
  uploadedAt   DateTime @default(now())

  invoice    PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  uploadedBy User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

// Pozycja oferty — lokal/parking/komórka itp. Snapshot cen z chwili dodania.
// discountType: PCT (procent) | AMOUNT_NET (kwota netto)
model OfferItem {
  id               String  @id @default(cuid())
  offerId          String
  unitId           String?
  position         Int     @default(0)
  // Snapshot z Unit (lub custom)
  label            String // np. "M-01" lub własny opis
  unitType         String // MIESZKALNY | USLUGOWY | PARKING | GARAZ | KOMORKA
  area             Float   @default(0)
  pricePerSqmNet   Float   @default(0)
  pricePerSqmGross Float   @default(0)
  priceNet         Float   @default(0) // cena całkowita pozycji netto (przed rabatem)
  priceGross       Float   @default(0)
  vatRate          Int     @default(8)
  // Rabat
  discountType     String  @default("PCT")
  discountValue    Float   @default(0) // w PCT albo w zł netto
  discountNet      Float   @default(0) // wyliczony rabat netto
  discountGross    Float   @default(0)
  // Wartości końcowe
  finalNet         Float   @default(0)
  finalGross       Float   @default(0)
  notes            String?

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  unit  Unit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([unitId])
}
