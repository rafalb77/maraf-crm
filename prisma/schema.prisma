generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// permissions: lista sekcji do których user ma dostęp (np. ['przeroby', 'clients']).
// Identyfikatory zdefiniowane w lib/permissions.ts (ALL_PERMISSIONS).
// Admin (NEXT_PUBLIC_ADMIN_EMAIL) ma override — jego permissions ignorowane, zawsze ma wszystko.
// Default [] — bezpieczny default; nowy user nie ma dostępu nigdzie dopóki admin nie nada.
// Istniejący userzy też dostaną [] po `prisma db push` — admin musi w /settings nadać im sekcje.
//
// Pola personalizacji (preferredName, interests, customInterests):
//  - preferredName — wyświetlane w powitaniu w dashboardzie (fallback: pierwsze słowo z name / email)
//  - interests — predefiniowane tematy newsów dnia (IDs z lib/news-feed.ts: tech, world, business, ...)
//  - customInterests — własne tematy free-form (max 50 znaków każdy, max 5 sztuk), fetch przez Google News search
//
// Endpoint /api/dashboard/widget czyta interests z DB po userId — zmiana działa natychmiast (bez re-login).
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String?
  preferredName    String?
  interests        String[]  @default([])
  customInterests  String[]  @default([])
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  permissions      String[]  @default([])
  createdAt        DateTime  @default(now())

  // Moduł Finanse
  createdInvoices            PurchaseInvoice[]           @relation("InvoiceCreator")
  createdPayments            PurchaseInvoicePayment[]    @relation("PaymentCreator")
  invoiceApprovals           PurchaseInvoiceApproval[]
  uploadedInvoiceAttachments PurchaseInvoiceAttachment[]
  createdSalesInvoices       SalesInvoice[]              @relation("SalesInvoiceCreator")
  createdSalesPayments       SalesInvoicePayment[]       @relation("SalesPaymentCreator")

  // Moduł Sprawy
  ownedCases                 Case[]                      @relation("CaseOwner")

  // Moduł Zadania
  assignedTasks              Task[]                      @relation("TaskAssignee")
}

// status: ZAPYTANIE | OFERTA | REZERWACJA | UMOWA | ODBIOR
model Client {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String?
  phone      String?
  phone2     String?
  pesel      String?
  nip        String?
  idNumber   String?
  fatherName String?
  motherName String?
  address    String?
  city       String?
  zipCode    String?
  status     String   @default("ZAPYTANIE")
  source     String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  activities      Activity[]
  clientUnits     ClientUnit[]
  serviceRequests ServiceRequest[]
  contracts       Contract[]
  contractClients ContractClient[]
  offers          Offer[]
  cases           Case[]
  tasks           Task[]
}

// type: MIESZKALNY | USLUGOWY | PARKING | GARAZ | KOMORKA
// status: WOLNY | ZAREZERWOWANY | SPRZEDANY | NIEDOSTEPNY
// reservationType: null | MIEKKA | REZERWACJA
model Unit {
  id                   String    @id @default(cuid())
  number               String    @unique
  type                 String
  area                 Float
  pricePerSqmNet       Float     @default(0)
  pricePerSqmGross     Float     @default(0)
  priceNet             Float
  priceGross           Float
  vatRate              Int       @default(8)
  floor                Int?
  rooms                Int?
  building             String?
  description          String?
  status               String    @default("WOLNY")
  // Data sprzedaży (ręczna) — zasila statystykę „co schodzi najszybciej" (soldAt − createdAt).
  // Ustawiana gdy status=SPRZEDANY; zmiana statusu na inny czyści pole (API units).
  soldAt               DateTime?
  floorPlanUrl         String?
  reservationType      String?
  reservationExpiresAt DateTime?
  reservedById         String?
  // Pola integracji z 3D Estate (matryca 3D) — patrz docs/integracja-3destate-decyzje.md
  // visibleOnMatrix=false ukrywa lokal na matrycy 3DE niezależnie od statusu (np. lokale przed wprowadzeniem do sprzedaży)
  visibleOnMatrix       Boolean   @default(true)
  // Promocje cenowe (rabat czasowy). promoActive=true → 3DE wyświetla cenę promo przekreśloną cenę bazową.
  // Uwaga Omnibus: 3DE liczy najniższą cenę z 30 dni po swojej stronie z odczytów naszego endpointu.
  promoPriceNet         Float?
  promoPriceGross       Float?
  promoPricePerSqmNet   Float?
  promoPricePerSqmGross Float?
  promoActive           Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  clientUnits      ClientUnit[]
  serviceRequests  ServiceRequest[]
  contractUnits    ContractUnit[]
  offerItems       OfferItem[]
  images           UnitImage[]
  creativeSettings UnitCreativeSettings?
  escrowDeposits   EscrowDeposit[]
  priceHistory     PriceHistory[]
  cases            Case[]
  tasks            Task[]
}

// Historia zmian ceny/statusu lokalu. Źródło „Daty od której obowiązuje oferta"
// w raporcie dane.gov.pl. Wspólny model z integracją 3D Estate (patrz
// docs/raportowanie-dane-gov-decyzje.md + docs/integracja-3destate-decyzje.md).
// Wpis powstaje przy tworzeniu lokalu i przy edycji jeśli cena/status się zmieniły
// (`lib/price-history.ts`).
model PriceHistory {
  id               String   @id @default(cuid())
  unitId           String
  pricePerSqmNet   Float
  pricePerSqmGross Float
  priceNet         Float
  priceGross       Float
  status           String
  changedAt        DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, changedAt])
}

// Dzienny snapshot CSV raportu cen dla dane.gov.pl. Harvester ministerstwa
// pobiera też zasoby historyczne — dlatego treść CSV musi być NIEZMIENNA per dzień,
// dlatego trzymamy ją w bazie (CSV+MD5) zamiast generować w locie. Endpoint
// `/api/public/dane-gov/file/[date].csv` serwuje zamrożoną treść. Cron upsertuje
// idempotentnie po `date`. Patrz docs/raportowanie-dane-gov-decyzje.md.
model DaneGovSnapshot {
  id        String   @id @default(cuid())
  date      String   @unique // YYYY-MM-DD wg Europe/Warsaw
  csv       String // pełna treść CSV (UTF-8 z BOM, CRLF, ~55 kolumn)
  md5       String // MD5 hash CSV — eksponowany jako .csv.md5 dla weryfikacji integralności
  rowCount  Int // liczba lokali w raporcie (do podglądu w panelu admina)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Zapamietane ustawienia generatora kreacji Meta Ads per lokal — zeby user
// nie ustawial ceny/CTA/hasla/tla za kazdym razem. Patrz docs/meta-ads-decyzje.md.
// backgrounds: JSON map { feed_square: "/uploads/...", feed_portrait: ..., story: ..., landscape: ... }
//   pusta wartosc dla formatu = auto-wybor tla.
model UnitCreativeSettings {
  id          String   @id @default(cuid())
  unitId      String   @unique
  priceMode   String   @default("FROM")
  ctaText     String   @default("Zobacz szczegóły")
  headline    String   @default("")
  backgrounds String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

// Galeria zdjec/wizualizacji per lokal. Uzywana do generowania kreacji
// reklamowych Meta Ads (FB/IG) — patrz docs/meta-ads-decyzje.md.
// floorPlanUrl na modelu Unit zostaje osobno (karta PDF mieszkania).
// isPrimary: zdjecie glowne (tlo kreacji reklamowej, miniaturka w listach).
// position: kolejnosc w galerii (drag-reorder w UI).
// kind: kategoria zdjecia (RZUT_3D | DOLL_HOUSE | WNETRZE | WIDOK_Z_OKNA | INNE) —
//   patrz UNIT_IMAGE_KIND_LABELS w lib/types.ts. Uzywana przez generator kreacji
//   do wyboru zdjecia per format (np. Story 9:16 = WNETRZE pionowe).
model UnitImage {
  id        String   @id @default(cuid())
  unitId    String
  url       String
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  kind      String   @default("INNE")
  createdAt DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, position])
}

// Wizualizacje wspolne dla calej inwestycji (Nova Staffa) — nie per-lokal,
// reuse'owane przez generator kreacji Meta Ads dla wszystkich lokali.
// Zarzadzane w /settings (admin only). Folder uploadow: public/uploads/investment/.
// kind: ZEWNETRZNE | WEWNETRZNE | OTOCZENIE | INNE — patrz INVESTMENT_IMAGE_KIND_LABELS.
model InvestmentImage {
  id        String   @id @default(cuid())
  url       String
  position  Int      @default(0)
  isPrimary Boolean  @default(false)
  kind      String   @default("INNE")
  createdAt DateTime @default(now())

  @@index([position])
}

model ClientUnit {
  id         String   @id @default(cuid())
  clientId   String
  unitId     String
  assignedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([clientId, unitId])
}

// type: NOTATKA | TELEFON | EMAIL | SPOTKANIE | DOKUMENT
model Activity {
  id        String   @id @default(cuid())
  clientId  String
  type      String   @default("NOTATKA")
  title     String
  content   String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// status: ZGLOSZONO | W_TOKU | ZAKONCZONE
// priority: NISKA | SREDNIA | WYSOKA
model ServiceRequest {
  id          String    @id @default(cuid())
  clientId    String
  unitId      String?
  title       String
  description String?
  status      String    @default("ZGLOSZONO")
  priority    String    @default("SREDNIA")
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  unit   Unit?  @relation(fields: [unitId], references: [id], onDelete: SetNull)
}

// =============================================================
// MODUŁ: SPRAWY (repozytorium spraw + korespondencja)
// =============================================================
// Reklamacje (rękojmia), sprawy urzędowe i inne — z osią korespondencji
// (pisma wysłane/odebrane jako skany), terminami ustawowymi i OCR skanów.
// Osobny moduł obok Serwisu (ServiceRequest). Patrz docs/sprawy-decyzje.md.
//
// type:     REKLAMACJA | URZEDOWA | INNE
// status:   NOWA | W_TOKU | OCZEKUJE | ROZSTRZYGNIETA | ZAMKNIETA
// priority: NISKA | SREDNIA | WYSOKA
model Case {
  id             String    @id @default(cuid())
  number         String    @unique // sygnatura: REK/2026/0042, URZ/2026/0007
  type           String    @default("REKLAMACJA")
  title          String
  description    String?
  status         String    @default("NOWA")
  priority       String    @default("SREDNIA")
  clientId       String?
  unitId         String?
  ownerId        String? // prowadzący sprawę (User)
  counterparty   String? // strona zewnętrzna (urząd/instytucja) gdy brak klienta
  receivedAt     DateTime? // data wpływu — start liczenia terminu
  deadline       DateTime? // termin odpowiedzi/załatwienia
  reminderSentAt DateTime? // idempotencja crona przypomnień
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client    Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  unit      Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  owner     User?          @relation("CaseOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  entries   CaseEntry[]
  documents CaseDocument[]
  tasks     Task[]

  @@index([status])
  @@index([deadline])
  @@index([clientId])
}

// Wpis w osi korespondencji sprawy.
// direction: PRZYCHODZACA | WYCHODZACA | WEWNETRZNA
// channel:   LIST | EMAIL | TELEFON | OSOBISCIE | EPUAP | INNE
model CaseEntry {
  id          String   @id @default(cuid())
  caseId      String
  direction   String   @default("PRZYCHODZACA")
  channel     String   @default("LIST")
  occurredAt  DateTime @default(now()) // data zdarzenia (≠ createdAt)
  subject     String?
  body        String?
  createdById String? // skalar bez FK (wzorzec AuditLog)
  createdAt   DateTime @default(now())

  case      Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  documents CaseDocument[]

  @@index([caseId, occurredAt])
}

// Dokument / skan podpięty do sprawy i opcjonalnie do konkretnego wpisu.
// ocrStatus: PENDING | DONE | FAILED | SKIPPED
model CaseDocument {
  id           String   @id @default(cuid())
  caseId       String
  entryId      String? // skan podpięty do konkretnego wpisu korespondencji
  filename     String
  url          String // /uploads/cases/<caseId>/<ts>-<safeName>
  mimeType     String
  size         Int?
  ocrText      String? // wynik OCR (Tesseract) — wyszukiwanie pełnotekstowe
  ocrStatus    String   @default("PENDING")
  uploadedById String? // skalar bez FK
  uploadedAt   DateTime @default(now())

  case  Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  entry CaseEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([caseId])
}

model CalendarToken {
  id           String    @id @default(cuid())
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// =============================================================
// MODUŁ: ZADANIA (centrum zadań „Do zrobienia" na pulpicie)
// =============================================================
// Zadania ręczne (source=MANUAL) + generowane automatycznie z danych
// (source=RULE) przez lib/tasks.ts: wygasające rezerwacje, zbliżające się
// raty harmonogramu. Reguły są idempotentne przez unikalny ruleKey
// (np. "RES_EXPIRE:<unitId>:<yyyy-mm-dd>") — wygenerowane raz zadanie nie
// powstanie ponownie, nawet po ręcznym odhaczeniu. Auto-domykanie: reconcile
// w lib/tasks.ts zamyka otwarte zadania RULE, których źródło przestało być
// aktualne (rata opłacona, rezerwacja przedłużona/zwolniona).
//
// type:   TELEFON | EMAIL | SPOTKANIE | REZERWACJA | PLATNOSC | SPRAWA | INNE
// status: OTWARTE | ZROBIONE | ANULOWANE
// source: MANUAL | RULE
model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  type          String    @default("INNE")
  status        String    @default("OTWARTE")
  dueAt         DateTime?
  pinned        Boolean   @default(false)
  snoozedUntil  DateTime? // drzemka — ukryte w widgecie do tej daty
  source        String    @default("MANUAL")
  ruleKey       String?   @unique
  autoCompleted Boolean   @default(false) // zamknięte przez reconcile, nie ręcznie
  completedAt   DateTime?
  completedById String? // skalar bez FK (wzorzec AuditLog)
  createdById   String? // skalar bez FK
  assigneeId    String? // null = pula wspólna (widoczne dla wszystkich)
  clientId      String?
  unitId        String?
  contractId    String?
  paymentId     String?
  caseId        String?
  googleEventId String? // faza 3: sync z Google Calendar
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignee User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  client   Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  unit     Unit?            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  contract Contract?        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payment  ContractPayment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  case     Case?            @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([status, dueAt])
  @@index([assigneeId, status])
}

// =============================================================
// AUDIT LOG — rejestr dostępu / zmian na danych wrażliwych
// =============================================================
// RODO Art. 30/32 — administrator musi wykazać kto, kiedy, jakie dane przeglądał
// lub zmieniał. Bez tego po incydencie nie da się oszacować zakresu wycieku.
//
// Logowanie selektywne (NIE każdy request), żeby tabela nie eksplodowała:
//  - LOGIN_SUCCESS / LOGIN_FAIL  — z lib/auth.ts authorize()
//  - VIEW_CLIENT                  — GET /api/clients/[id] (kto oglądał dane konkretnego klienta z PESEL)
//  - CREATE / UPDATE / DELETE     — POST/PATCH/DELETE na wrażliwych encjach
//  - EXPORT                       — pobranie PDF/xlsx z danymi klientów
//  - PERMISSION_CHANGE            — admin zmienił komuś permissions
//
// action: enum-string. entity/entityId: na co działanie się odnosiło (np. Client/cli_xyz).
// metadata: opcjonalny JSON z dodatkowymi info (np. starych wartości przy UPDATE).
//
// Retencja: na razie BEZ auto-cleanup. RODO sugeruje przynajmniej 12 mc dla audit
// (proporcjonalnie do ryzyka). Po roku można dodać cron usuwający > 12 mc.
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?  // null gdy LOGIN_FAIL bez znanego usera
  userEmail String?  // duplikat do filtrowania (nawet po usunięciu Usera log zostaje)
  action    String   // LOGIN_SUCCESS | LOGIN_FAIL | VIEW_CLIENT | CREATE | UPDATE | DELETE | EXPORT | PERMISSION_CHANGE | ...
  entity    String?  // 'Client' | 'Unit' | 'Offer' | 'Contract' | 'User' | 'PurchaseInvoice' | ...
  entityId  String?
  path      String?  // ścieżka URL żądania (do debugu)
  ip        String?
  userAgent String?
  metadata  String?  // JSON stringified — old/new values, reason, etc.

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
}

// type: REZERWACYJNA | DEWELOPERSKA | PRZENIESIENIA
// status: W_PRZYGOTOWANIU | PODPISANA | ROZWIAZANA | ANULOWANA
model Contract {
  id              String    @id @default(cuid())
  number          String    @unique
  type            String
  status          String    @default("W_PRZYGOTOWANIU")
  investmentName  String    @default("Inwestycja")
  clientId        String
  introducedAt    DateTime  @default(now())
  plannedSignDate DateTime?
  signedAt        DateTime?
  reservationFee  Float?
  reservationFeeDays Int    @default(7) // termin wpłaty opłaty = data podpisania + N dni
  reservationEndDate DateTime? // termin zakończenia rezerwacji — trafia do DOCX ({{reservationEndDate}})
  discount        Float?
  valueNet        Float?
  valueGross      Float?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contractClients ContractClient[]
  contractUnits   ContractUnit[]
  attachments     ContractAttachment[]
  history         ContractHistory[]
  payments        ContractPayment[]
  stages          ContractStage[]
  tasks           Task[]
}

// Etapy dealu. Jeden Contract = jeden deal; `Contract.type` = BIEŻĄCY etap.
// Deal przechodzi: REZERWACYJNA → DEWELOPERSKA → PRZENIESIENIA (może też
// startować od dowolnego etapu, np. od razu deweloperskiej). Każdy etap to
// osobny podpisany dokument — własna data podpisania i opcjonalny numer aktu
// notarialnego (repertorium). Numer dealu (Contract.number) jest jeden.
// stage:  REZERWACYJNA | DEWELOPERSKA | PRZENIESIENIA
// status: W_PRZYGOTOWANIU | PODPISANA | ROZWIAZANA | ANULOWANA
model ContractStage {
  id              String    @id @default(cuid())
  contractId      String
  stage           String
  status          String    @default("W_PRZYGOTOWANIU")
  number          String? // numer aktu / repertorium notarialne dla tego etapu
  plannedSignDate DateTime?
  signedAt        DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, stage])
  @@index([contractId])
}

// Harmonogram wpłat nabywcy (etap 2 Finansowania). Umowa deweloperska ma raty
// planowane (plannedDate/plannedAmount), które Marta odhacza jako opłacone
// (status PLANOWANA → OPLACONA). Przy odhaczeniu raty z toEscrow=true tworzy się
// automatycznie EscrowDeposit na rachunku powierniczym MD.
// type: ZALICZKA | RATA | KONCOWA | REZERWACYJNA
// status: PLANOWANA | OPLACONA
model ContractPayment {
  id            String    @id @default(cuid())
  contractId    String
  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  title         String?   // np. "I rata", "Transza po stanie surowym"
  type          String    @default("RATA")
  plannedDate   DateTime?
  plannedAmount Float     @default(0)
  status        String    @default("PLANOWANA")
  paidDate      DateTime?
  paidAmount    Float?
  toEscrow      Boolean   @default(false) // czy wpłata trafia na rachunek powierniczy
  note          String?
  position      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  escrowDeposit EscrowDeposit? // back-relation (1:1, link tworzony przy odhaczeniu)
  tasks         Task[]

  @@index([contractId])
  @@index([status])
}

model ContractClient {
  id         String @id @default(cuid())
  contractId String
  clientId   String
  position   Int    @default(1)

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([contractId, clientId])
}

model ContractUnit {
  id         String @id @default(cuid())
  contractId String
  unitId     String
  // Snapshot ceny lokalu NA UMOWIE (z oferty lub po rabacie przy tworzeniu).
  // Zamrożona — umowa nie zmienia kwot, gdy później ktoś zmieni cennik lokalu.
  // null = brak snapshotu (legacy) → generator użyje ceny bazowej z Unit.
  priceNet   Float?
  priceGross Float?

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([contractId, unitId])
}

// =============================================================
// MODUŁ: OBMIARY Z RYSUNKÓW (DXF/PDF)
// =============================================================

// Projekt rysunkowy (np. "Budynek A – Kondygnacja 0")
model DrawingProject {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("KONSTRUKCYJNY") // ARCHITEKTONICZNY | KONSTRUKCYJNY | INSTALACYJNY
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  drawings Drawing[]
}

// Rysunek (plik DXF/PDF/DWG)
model Drawing {
  id             String   @id @default(cuid())
  projectId      String?
  name           String
  originalName   String
  fileType       String // DXF | PDF | DWG | IMAGE
  filePath       String
  fileSize       Int?
  scaleLabel     String   @default("1:50") // np. "1:50", "1:100"
  pixelsPerMeter Float? // kalibracja: ile px = 1m
  pageWidth      Int?
  pageHeight     Int?
  status         String   @default("UPLOADED") // UPLOADED | READY | ERROR
  aiAnalyzed     Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project  DrawingProject?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  elements DrawingElement[]
}

// Typ elementu: konstrukcyjny lub architektoniczny
// KONSTRUKCYJNY: STROP | PODCIAG | SLUP | WIENIEC | SCIANA_ZB | LAW_FUND | STOP_FUND | NADPROZ
// ARCHITEKTONICZNY: ELEWACJA | TYNK_ZEW | TYNK_WEW | POSADZKA | DACH | OKNO | DRZWI | OCIEPLENIE
model DrawingElement {
  id         String   @id @default(cuid())
  drawingId  String
  type       String // patrz komentarz wyżej
  label      String // np. "Strop nad parterem", "Słup S-01"
  floor      String? // "PIWNICA" | "PARTER" | "PIETRO_1" | ...
  geometry   String // JSON: [{x,y},...] punkty w px na canvas
  // Przeliczone wymiary (w metrach)
  lengthM    Float?
  widthM     Float?
  heightM    Float?
  perimeterM Float?
  areaM2     Float?
  volumeM3   Float?
  // Szacunki materiałowe
  concreteM3 Float? // beton wg normy
  steelKg    Float? // stal wg wskaźnika kg/m³ lub kg/m²
  // Rozliczenie
  unit       String   @default("M2") // M2 | M3 | MB | SZT | KG | T
  qty        Float    @default(0)
  notes      String?
  verified   Boolean  @default(false)
  source     String   @default("MANUAL") // MANUAL | AI | DXF_AUTO
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  drawing Drawing @relation(fields: [drawingId], references: [id], onDelete: Cascade)
}

model ContractAttachment {
  id         String   @id @default(cuid())
  contractId String
  filename   String
  url        String
  size       Int?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model ContractHistory {
  id         String   @id @default(cuid())
  contractId String
  event      String
  details    String?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

// =============================================================
// MODUŁ: PRZEROBY (kontroling protokołów przerobowych)
// =============================================================

// Podwykonawca — firma wykonawcza
model Subcontractor {
  id          String   @id @default(cuid())
  name        String
  nip         String?
  regon       String?
  address     String?
  city        String?
  zipCode     String?
  contactName String?
  email       String?
  phone       String?
  bankAccount String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts SubContract[]
  protocols Protocol[]
}

// Umowa z podwykonawcą — kosztorys umowny w pozycjach (ContractWorkItem)
model SubContract {
  id              String    @id @default(cuid())
  subcontractorId String
  number          String?
  title           String
  scopeText       String? // np. "Roboty konstrukcyjne"
  signedAt        DateTime?
  startDate       DateTime?
  endDate         DateTime?
  // valueNet — wyliczana z protokołów: Σ(ContractWorkItem.plannedQty × unitPrice).
  // Obejmuje TYLKO pozycje które weszły do dotychczasowych protokołów — czyli
  // zafakturowany zakres, NIE cała umowa. Nadpisywana przy każdym imporcie.
  valueNet        Float?
  // agreedValueNet — umowna wartość netto z dokumentu umowy (CAŁY zakres robót:
  // wszystkie kondygnacje + dach). Wpisywana ręcznie w UI. Importer jej NIE dotyka.
  // To prawidłowy mianownik wskaźnika "% kontraktu" w widoku protokołu.
  agreedValueNet  Float?
  retentionPct    Float     @default(0)
  status          String    @default("AKTYWNA") // AKTYWNA | ZAKONCZONA | ANULOWANA
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subcontractor Subcontractor      @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  workItems     ContractWorkItem[]
  protocols     Protocol[]
}

// Pozycja umowna (kosztorys) — jedna linia w protokole przerobowym.
// Np. "Zaszalowanie i zabetonowanie ław fundamentowych" m³ 540 zł/m³, plan 76,55.
model ContractWorkItem {
  id          String   @id @default(cuid())
  contractId  String
  section     String? // "FUNDAMENTY", "PARTER", "I Piętro" (kondygnacja)
  position    Int      @default(0) // numer w sekcji
  globalOrder Int      @default(0) // globalny porządek w umowie
  name        String // opis prac
  unit        String // m3 | m2 | T | kpl | mb | stopni | kg
  unitPrice   Float    @default(0)
  plannedQty  Float    @default(0) // ilość planowana
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contract      SubContract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  protocolItems ProtocolItem[]

  @@index([contractId, globalOrder])
}

// Zakres robót — branża/etap (np. Konstrukcja żelbetowa, Prace murarskie, Tynki...)
// Każdy zakres ma własny obmiar i własne kategorie.
model WorkScope {
  id          String   @id @default(cuid())
  name        String   @unique // "Konstrukcja żelbetowa"
  slug        String   @unique // "konstrukcja-zelbetowa"
  order       Int      @default(0)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  categories     WorkCategory[]
  floorSummaries FloorSummary[]
}

// Kategoria robót = jeden arkusz Excela (Fundamenty, Piony 0, Belki nad 0...)
// należy do konkretnego zakresu (WorkScope).
model WorkCategory {
  id          String   @id @default(cuid())
  scopeId     String
  name        String
  slug        String
  order       Int      @default(0)
  primaryUnit String   @default("M3") // M3 | M2 | SZT
  description String?
  createdAt   DateTime @default(now())

  scope WorkScope  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  items WorkItem[]

  @@unique([scopeId, slug])
}

// Powiązanie odwrotne — WorkScope ma summaries
// (Prisma wymaga relacji w obie strony)

// Podsumowanie kondygnacji — agregat kierownika łączący obmiar inżynierski
// z pozycjami umownymi (i protokołami). Per kondygnacja: PARTER, I_PIETRO, ...
model FloorSummary {
  id         String   @id @default(cuid())
  scopeId    String // np. konstrukcja-zelbetowa
  floor      String // "PARTER", "I_PIETRO", "II_PIETRO", "DACH"
  source     String? // ścieżka pliku xlsx
  importedAt DateTime @default(now())
  notes      String?

  scope WorkScope          @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  items FloorSummaryItem[]

  @@unique([scopeId, floor])
}

// Pojedyncza pozycja w podsumowaniu kondygnacji (np. „Zaszalowanie ścian parteru").
// matchMode określa czy porównanie z obmiarem inżynierskim jest automatyczne czy ręczne.
//   AUTO_OK            — reguła mapowania działa, wartość liczona z obmiaru
//   MANUAL_FLOOR_SPLIT — element rozpięty na kilku kondygnacjach (ściany, słupy, trzpienie)
//   MANUAL_DIFF_UNIT   — różna jednostka (np. schody kpl vs szt biegów)
//   MANUAL_OUT_OF_SCOPE— poza zakresem ŻB (murowanie, łączniki)
//   MANUAL_NOT_FOUND   — pozycja nieobecna w obmiarze inżynierskim (np. daszki)
//   MANUAL_OVERRIDE    — użytkownik świadomie nadpisał wartość
//   MANUAL_ADDED       — pozycja dodana ręcznie przez usera w UI (poza pozycjami z buildPositionsForFloor); zachowywane przy reimporcie
model FloorSummaryItem {
  id          String @id @default(cuid())
  summaryId   String
  position    Int    @default(0)
  name        String
  unit        String // m3, m2, mb, kpl, szt, T, kg
  laborQty    Float  @default(0) // "Robocizny" — to co rozliczane w protokole
  concreteVol Float  @default(0) // m³ betonu C25/30
  rebarMass   Float  @default(0) // kg zbrojenia

  matchMode             String    @default("AUTO_OK")
  matchReason           String? // automatyczny opis dlaczego nie matchuje
  mappingRule           String? // JSON: { categoryName, elementType?, floorName?, namePattern? }
  manualValue           Float? // ręczna wartość Marafu (override autoValue z reguły)
  manualNote            String? // komentarz do manualValue
  konradManualValue     Float? // ręczna wartość Konrada (gdy nie ma detalu w xlsx) — wpisuje kierownik lub admin
  konradManualReason    String? // uzasadnienie wartości Konrada — WYMAGANE gdy |Δ| > 5% vs Maraf
  // DEPRECATED — zastąpione przez investorApproved*. Pola zostają w schemie/bazie żeby
  // nie tracić historycznych danych (kto co kiedy kierowniczo zaakceptował). Nie używane w UI.
  accepted              Boolean   @default(false)
  acceptedAt            DateTime?
  acceptedNote          String?
  // Akceptacja przez Inwestora (admin) — warunek konieczny przejścia pozycji do protokołu.
  // investorApprovedValue = snapshot wartości kierownika w momencie akceptacji (do auditingu —
  // jeśli wartość się zmieni po akceptacji, widać że potrzeba reakceptacji).
  investorApproved      Boolean   @default(false)
  investorApprovedBy    String?
  investorApprovedAt    DateTime?
  investorApprovedNote  String?
  investorApprovedValue Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  summary FloorSummary              @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  history FloorSummaryItemHistory[]

  @@index([summaryId])
}

// Historia zmian per pozycja podsumowania — auditing dla ręcznych decyzji kierownika
// (akceptacja różnicy, wpis ręcznej wartości Marafu/Konrada, komentarze).
model FloorSummaryItemHistory {
  id        String   @id @default(cuid())
  itemId    String
  action    String // ACCEPT | UNACCEPT | SET_MANUAL_VALUE | CLEAR_MANUAL_VALUE | SET_KONRAD_VALUE | CLEAR_KONRAD_VALUE | INVESTOR_APPROVE | INVESTOR_UNAPPROVE | ITEM_ADDED | EDIT_NOTE | REIMPORT
  oldValue  String? // poprzednia wartość (JSON serialized)
  newValue  String? // nowa wartość (JSON serialized)
  note      String? // komentarz / uzasadnienie z formularza
  userEmail String? // email użytkownika z sesji
  createdAt DateTime @default(now())

  item FloorSummaryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
}

// Pozycja obmiaru (master, niezmienna po imporcie)
// primaryUnit dziedziczy z kategorii ale może być nadpisana per pozycja
model WorkItem {
  id          String  @id @default(cuid())
  categoryId  String
  floor       String? // "Kondygnacja 0", "+1", "Dach"
  elementType String? // "Ławy fund.", "Słupy 0", "Belki stropu K0"
  name        String // "Łf-01", "S-P.01"
  count       Int? // liczba sztuk
  lengthM     Float?
  widthM      Float?
  heightM     Float?
  areaM2      Float?
  volumeM3    Float?
  primaryUnit String  @default("M3") // którą wartością rozliczamy
  primaryQty  Float   @default(0) // wartość w primaryUnit (np. V dla M3, A dla M2)
  notes       String?
  sourceRow   Int? // numer wiersza w Excelu (debug)

  category WorkCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

// Protokół przerobowy — okres rozliczeniowy (od/do), powiązany z umową
// status: SZKIC | ZATWIERDZONY | ZAFAKTUROWANY | ANULOWANY
model Protocol {
  id              String    @id @default(cuid())
  number          String?
  subcontractorId String
  contractId      String
  periodFrom      DateTime
  periodTo        DateTime
  // Cache miesiąca/roku do sortowania i list (= miesiąc/rok periodTo)
  periodYear      Int
  periodMonth     Int
  status          String    @default("SZKIC")
  issuedAt        DateTime  @default(now())
  approvedAt      DateTime?
  invoicedAt      DateTime?
  notes           String?
  totalNet        Float     @default(0) // suma w tym okresie
  retentionAmount Float     @default(0)
  payableNet      Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subcontractor Subcontractor  @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  contract      SubContract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  items         ProtocolItem[]
}

// Pozycja w protokole — odnosi się do pozycji umownej (ContractWorkItem).
// qty = ilość wykonana w TYM okresie (delta).
model ProtocolItem {
  id                 String  @id @default(cuid())
  protocolId         String
  contractWorkItemId String
  qty                Float   @default(0)
  unit               String  @default("m3")
  unitPrice          Float   @default(0)
  amountNet          Float   @default(0)
  note               String?
  // Ręczne porównanie z obmiarem Maraf — gdy auto-dopasowanie (lib/protokol-maraf-match.ts)
  // jest niepewne, błędne lub brakuje reguły, user wpisuje wartość ręcznie.
  // Wpisana wartość NADPISUJE auto-match w kolumnie "Maraf (obmiar)" w UI protokołu.
  // marafManualValue jest w jednostce pozycji protokołu (ProtocolItem.unit).
  marafManualValue   Float?
  marafManualNote    String?

  protocol         Protocol         @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  contractWorkItem ContractWorkItem @relation(fields: [contractWorkItemId], references: [id], onDelete: Restrict)

  @@index([protocolId])
  @@index([contractWorkItemId])
}

// =============================================================
// MODUŁ: KALKULATOR OFERTY (CRM)
// =============================================================
// status: SZKIC | WYSLANA | ZAAKCEPTOWANA | ODRZUCONA | ANULOWANA
model Offer {
  id                 String    @id @default(cuid())
  number             String?   @unique
  clientId           String?
  title              String?
  validUntil         DateTime?
  status             String    @default("SZKIC")
  notes              String?
  // Sumy snapshot (przeliczane przy każdej zmianie pozycji)
  subtotalNet        Float     @default(0) // suma netto przed rabatem
  subtotalGross      Float     @default(0) // suma brutto przed rabatem
  totalDiscountNet   Float     @default(0)
  totalDiscountGross Float     @default(0)
  totalNet           Float     @default(0) // po rabacie
  totalGross         Float     @default(0) // po rabacie
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items  OfferItem[]
}

// =============================================================
// MODUŁ: FINANSE (faktury zakupowe + workflow akceptacji)
// =============================================================
// Zastępuje plik PŁATNOŚCI 2026.xlsx (siostra Marta wprowadza, tata Bohdan
// akceptuje kolorem). Patrz docs/finanse-rozpoczecie.md.
//
// Workflow: WPROWADZONA → DO_ZATWIERDZENIA → ZATWIERDZONA/ODRZUCONA → OPLACONA
// Permissions: 'finanse' (czyta+wprowadza), 'finanse.approve' (zatwierdza).

// category: DOSTAWCA | BANK | LEASING | URZAD | PODWYKONAWCA | INNE
model Vendor {
  id        String   @id @default(cuid())
  name      String   @unique
  shortCode String?
  nip       String?
  category  String   @default("DOSTAWCA")
  notes     String?
  isActive  Boolean  @default(true)
  // Domyślne % kaucji gwarancyjnej i kosztów budowy dla tego kontrahenta.
  // Prefilują pola faktury przy tworzeniu (user może nadpisać per FV).
  defaultDepositPct       Float?
  defaultBuildingCostsPct Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices PurchaseInvoice[]
}

// status: WPROWADZONA | DO_ZATWIERDZENIA | ZATWIERDZONA | ZAPLANOWANA | OPLACONA | CZESCIOWO_OPLACONA | ODRZUCONA | ANULOWANA
//
// Workflow:
//  WPROWADZONA       — Marta wpisała, nie wysłała jeszcze do akceptacji
//  DO_ZATWIERDZENIA  — w inboksie Bohdana
//  ZATWIERDZONA      — Bohdan zaakceptował, Marta może płacić
//  ZAPLANOWANA       — Marta zleciła przelew, ale nie wykonano (opcjonalne)
//  OPLACONA          — Σ(payments.amount) >= amountGross
//  CZESCIOWO_OPLACONA — 0 < Σ(payments) < amountGross
//  ODRZUCONA         — Bohdan odrzucił (komentarz wymagany); Marta poprawia → wraca do WPROWADZONA
//  ANULOWANA         — faktura skorygowana, anulowana po stronie dostawcy
//
// importedFromColor — jaki kolor wiersza był w xlsx przy imporcie (do auditu mapowania).
// subVendor — dla zakładek STAFFA/MURARZ gdzie w kol A jest subkontrahent (PATRIMEX, AL-BUD).
model PurchaseInvoice {
  id                String    @id @default(cuid())
  number            String // numer faktury od dostawcy (FV)
  // company — która z naszych firm ponosi koszt: MARAF | MARAF_DEVELOPMENT.
  // Multi-firma od początku (decyzja 2026-05-21). Default MARAF (import historii to Maraf).
  // W przyszłości: FV przychodowa Marafu dla MD generuje tu wpis kosztowy z company=MARAF_DEVELOPMENT.
  company           String    @default("MARAF")
  vendorId          String
  subVendor         String?
  issueDate         DateTime
  dueDate           DateTime?
  vatRate           Float // 0.23, 0.08, 0.05
  amountGross       Float
  amountNet         Float
  amountVat         Float
  currency          String    @default("PLN")
  status            String    @default("WPROWADZONA")
  // category — ręczna kategoria kosztowa per faktura (osobna od folderów
  // vendorowych w lib/finanse-folders.ts): STAFFA | STALE | TYNKI | INNE.
  // Przypisywana w szczegółach faktury. null = nieprzypisana.
  category          String?
  description       String? // np. "murowanie ścian I piętro" (z MURARZ.M)
  notes             String?
  // Potracenia z faktury podwykonawcy (głównie podwykonawcy budowlani):
  //  deposit       — kaucja gwarancyjna (zatrzymana, ZWRACANA po okresie gwarancji)
  //  buildingCosts — koszty budowy/refaktury (potracenie BEZZWROTNE)
  //  electricity   — prad (potracenie bezzwrotne)
  // Kwota faktycznie nalezna podwykonawcy = brutto - deposit - buildingCosts - electricity.
  deposit           Float?
  depositPct        Float? // % kaucji (opcjonalny — gdy wpisany jako procent; kwota w deposit)
  depositReturnDate DateTime? // termin zwrotu kaucji (wpisywany ręcznie)
  depositReturnedAt DateTime? // kiedy faktycznie zwrócona (null = jeszcze zatrzymana)
  buildingCosts     Float?
  buildingCostsPct  Float? // % kosztów budowy (analogicznie do depositPct)
  electricity       Float?
  // Pola powiązań przyszłościowych (Faza 2)
  investmentId      String? // przyszłość: powiązanie z inwestycją
  saldeoId          String? // ID faktury w Saldeo (po integracji w Fazie 2)
  // Cross-company: gdy ten koszt powstał z faktury przychodowej innej firmy grupy
  // (np. Maraf wystawił FV dla MD → tu koszt w MD). ID źródłowej SalesInvoice.
  sourceSalesInvoiceId String?
  // KSeF — numer faktury w Krajowym Systemie e-Faktur. Unique zapobiega
  // duplikatom przy synchronizacji (faktura pobrana z KSeF nie zostanie wczytana 2x).
  ksefNumber String? @unique
  // KSeF — pełny snapshot z FA(3): dane sprzedawcy/nabywcy (adres, kontakt),
  // pozycje faktury (FaWiersz) i info o płatności. READ-only do wyświetlenia
  // w szczegółach. Kształt: lib/types.ts → KsefInvoiceData.
  ksefData   Json?
  // Audit
  importedFromColor String? // np. "FFE6B8AF" — z którego koloru w xlsx
  importSheet       String? // np. "STAFFA" — z której zakładki
  importRow         Int? // numer wiersza w xlsx (debug)
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  vendor      Vendor                      @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  createdBy   User?                       @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  payments    PurchaseInvoicePayment[]
  approvals   PurchaseInvoiceApproval[]
  attachments PurchaseInvoiceAttachment[]

  @@unique([vendorId, number])
  @@index([status, dueDate])
  @@index([vendorId, issueDate])
  @@index([dueDate])
  @@index([company, status])
  @@index([depositReturnDate])
  @@index([category])
}

// Bookkeeping płatności — 1 faktura = N płatności (wspiera częściowe).
// Płatności NIE wymagają osobnej akceptacji (decyzja 2026-05-17 — Bohdan
// akceptuje całą fakturę raz, Marta dowolnie wiele płatności do niej).
model PurchaseInvoicePayment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Float
  paidAt      DateTime
  bankAccount String? // skrót banku: ING, Santander, mBank...
  reference   String? // tytuł przelewu
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  invoice   PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("PaymentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([paidAt])
}

// action: SUBMITTED | APPROVED | REJECTED | RESET | EDITED
// Audit trail decyzji akceptacyjnych. SUBMITTED = Marta wysłała do akceptacji.
// APPROVED/REJECTED = decyzja Bohdana. RESET = cofnięcie do WPROWADZONA (np. po edycji).
model PurchaseInvoiceApproval {
  id        String   @id @default(cuid())
  invoiceId String
  action    String
  comment   String?
  userId    String?
  userEmail String? // snapshot na wypadek usunięcia usera
  createdAt DateTime @default(now())

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([invoiceId, createdAt])
}

model PurchaseInvoiceAttachment {
  id           String   @id @default(cuid())
  invoiceId    String
  filename     String
  url          String // ścieżka pod /uploads/finanse/...
  mimeType     String
  size         Int?
  uploadedById String?
  uploadedAt   DateTime @default(now())

  invoice    PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  uploadedBy User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

// =============================================================
// FINANSE: FAKTURY PRZYCHODOWE (sprzedazowe) — wystawiane przez nas.
// Patrz docs/finanse-rozpoczecie.md grupa F.
// =============================================================
// status: WYSTAWIONA | CZESCIOWO_OPLACONA | OPLACONA | ANULOWANA
// company — ktora nasza firma WYSTAWIA fakture (MARAF | MARAF_DEVELOPMENT).
// recipientName — odbiorca (FIRMA z Excela Marty).
// recipientCompany — gdy odbiorca to firma grupy (np. Maraf wystawia dla MD):
//   MARAF | MARAF_DEVELOPMENT. Pod cross-company (grupa G — auto-koszt u odbiorcy).
// deposit — kaucja zatrzymana przez klienta z naszej faktury (dostajemy mniej).
// buildingCosts — koszty budowy potracone przez klienta.
// isAdvance — faktura zaliczkowa: NIE wliczana do CIT/VAT dopoki nie skonwertowana
//   na zwykla (isAdvance=false). Kwota nalezna = brutto - kaucja - KB.
model SalesInvoice {
  id               String    @id @default(cuid())
  company          String    @default("MARAF")
  number           String
  recipientName    String
  recipientCompany String?
  issueDate        DateTime
  dueDate          DateTime?
  vatRate          Float
  amountNet        Float
  amountVat        Float
  amountGross      Float
  currency         String    @default("PLN")
  deposit          Float?
  buildingCosts    Float?
  isAdvance        Boolean   @default(false)
  status           String    @default("WYSTAWIONA")
  description      String?
  notes            String?
  // Cross-company: gdy z tej FV przychodowej utworzono koszt u odbiorcy (firma grupy).
  // ID utworzonej PurchaseInvoice — zapobiega duplikatom.
  linkedPurchaseInvoiceId String?
  // KSeF — patrz analogiczne pola w PurchaseInvoice.
  ksefNumber       String?   @unique
  ksefData         Json?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  createdBy User?                 @relation("SalesInvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  payments  SalesInvoicePayment[]

  @@unique([company, number])
  @@index([company, issueDate])
  @@index([status, dueDate])
  @@index([recipientCompany])
}

model SalesInvoicePayment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Float
  paidAt      DateTime
  reference   String?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("SalesPaymentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([paidAt])
}

// KSeF — konfiguracja per firma (Maraf / Maraf Development). Pobieranie faktur
// (read-only) z Krajowego Systemu e-Faktur. Patrz docs/finanse-ksef-rozpoczecie.md.
//
// token: token KSeF wygenerowany w ksef.podatki.gov.pl przez osobę z uprawnieniami.
//   TODO: szyfrować (na razie plain — admin only access).
// environment: PROD (ksef.podatki.gov.pl) | TEST (do testów integracji).
// syncFromDate: od kiedy pobierać faktury. Decyzja 2026-05-21: 2026-06-01 dla obu firm.
// lastSyncStatus: NEVER | OK | ERROR.
model KsefConfig {
  id              String    @id @default(cuid())
  company         String    @unique  // MARAF | MARAF_DEVELOPMENT
  nip             String
  token           String?
  environment     String    @default("PROD")
  enabled         Boolean   @default(false)
  syncFromDate    DateTime?
  lastSyncAt      DateTime?
  lastSyncStatus  String    @default("NEVER")
  lastSyncError   String?
  lastSyncCount   Int?      // ile faktur zaciągnięto w ostatniej synchronizacji
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Pozycja oferty — lokal/parking/komórka itp. Snapshot cen z chwili dodania.
// discountType: PCT (procent) | AMOUNT_NET (kwota netto)
model OfferItem {
  id               String  @id @default(cuid())
  offerId          String
  unitId           String?
  position         Int     @default(0)
  // Snapshot z Unit (lub custom)
  label            String // np. "M-01" lub własny opis
  unitType         String // MIESZKALNY | USLUGOWY | PARKING | GARAZ | KOMORKA
  area             Float   @default(0)
  pricePerSqmNet   Float   @default(0)
  pricePerSqmGross Float   @default(0)
  priceNet         Float   @default(0) // cena całkowita pozycji netto (przed rabatem)
  priceGross       Float   @default(0)
  vatRate          Int     @default(8)
  // Rabat
  discountType     String  @default("PCT")
  discountValue    Float   @default(0) // w PCT albo w zł netto
  discountNet      Float   @default(0) // wyliczony rabat netto
  discountGross    Float   @default(0)
  // Wartości końcowe
  finalNet         Float   @default(0)
  finalGross       Float   @default(0)
  notes            String?

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  unit  Unit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([offerId])
  @@index([unitId])
}

// =============================================================
// MODUŁ: FINANSOWANIE INWESTYCJI (kredyty + rachunki powiernicze + zwroty VAT)
// Widoczny tylko dla MARAF_DEVELOPMENT (deweloper). Maraf (generalny wykonawca)
// nie ma kredytów ani escrow.
// Patrz docs/finanse-decyzje.md sekcja "Finansowanie inwestycji".
// =============================================================

// Kredyt bankowy. type INWESTYCYJNY = pod inwestycję, transze wpływają na konto MD,
// spłacane z bieżącego konta. type VAT = bank płaci VAT z faktur kosztowych bezpośrednio
// do dostawcy, spłacany ze zwrotów VAT z US. OBROTOWY/INNE = pozostałe.
// status: AKTYWNY | ZAMKNIETY
model Loan {
  id             String   @id @default(cuid())
  company        String   @default("MARAF_DEVELOPMENT")
  name           String   // np. "Kredyt inwestycyjny ING 2026"
  bank           String
  contractNumber String?
  type           String   @default("INWESTYCYJNY") // INWESTYCYJNY | VAT | OBROTOWY | INNE
  limit          Float    // limit kredytu
  interestRate   Float?   // % oprocentowanie (info, nie do liczeń)
  signedAt       DateTime
  expiresAt      DateTime?
  status         String   @default("AKTYWNY")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tranches   LoanTranche[]
  repayments LoanRepayment[]
  vatRefundsApplied VatRefund[] @relation("VatRefundsToLoan")

  @@index([company])
  @@index([type])
}

// Wypłata transzy kredytu. Dla type INWESTYCYJNY: wpływa na konto MD.
// Dla type VAT: bank przelewa bezpośrednio do dostawcy (nie przez MD), ale
// rejestrujemy zbiorczo per miesiąc/kwartał.
model LoanTranche {
  id        String   @id @default(cuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  date      DateTime
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  @@index([loanId])
  @@index([date])
}

// Spłata kredytu. principal=kapitał, interest=odsetki, fees=prowizje/ubezp.
// Suma trzech = jeden przelew do banku. Odsetki NIE są wpisywane jako FV kosztowa
// (decyzja 2026-06-02 — bank pobiera kapitał+odsetki jednym przelewem bez FV).
model LoanRepayment {
  id        String   @id @default(cuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  date      DateTime
  principal Float    @default(0)
  interest  Float    @default(0)
  fees      Float    @default(0)
  note      String?
  createdAt DateTime @default(now())

  @@index([loanId])
  @@index([date])
}

// Zwrot VAT z Urzędu Skarbowego. Może być przeznaczony na spłatę kredytu VAT
// (appliedToLoanId) lub trafiać na konto operacyjne.
model VatRefund {
  id              String   @id @default(cuid())
  company         String   @default("MARAF_DEVELOPMENT")
  date            DateTime
  amount          Float
  periodLabel     String?  // np. "Q2 2026", "maj 2026"
  appliedToLoanId String?
  appliedToLoan   Loan?    @relation("VatRefundsToLoan", fields: [appliedToLoanId], references: [id], onDelete: SetNull)
  note            String?
  createdAt       DateTime @default(now())

  @@index([company])
  @@index([date])
}

// Rachunek powierniczy (escrow). type OMRP = otwarty mieszkaniowy (uwolnienia
// po milestone'ach), ZMRP = zamknięty (uwolnienie raz, po przeniesieniu własności).
// Powiązany z konkretną inwestycją (investmentName tekstowo; w przyszłości link do Investment).
model EscrowAccount {
  id             String   @id @default(cuid())
  company        String   @default("MARAF_DEVELOPMENT")
  name           String   // np. "OMRP Nova Staffa etap 1"
  bank           String
  accountNumber  String?
  type           String   @default("OMRP") // OMRP | ZMRP
  investmentName String?
  status         String   @default("AKTYWNY") // AKTYWNY | ZAMKNIETY
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deposits EscrowDeposit[]
  releases EscrowRelease[]

  @@index([company])
}

// Wpłata nabywcy na rachunek powierniczy. Te pieniądze są w banku, ale jeszcze NIE
// należą do MD — uwalniają się po milestone'ach (EscrowRelease).
// W etapie 1 wpisywane ręcznie. W etapie 2 (rozbudowa modułu Sprzedaż) — auto z ContractPayment.
model EscrowDeposit {
  id             String   @id @default(cuid())
  accountId      String
  account        EscrowAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date           DateTime
  amount         Float
  buyerName      String?
  contractNumber String?  // tekstowe w etapie 1; w etapie 2 wypełniane z Contract.number
  unitId         String?
  unit           Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  // Etap 2: twardy link do raty harmonogramu. onDelete Cascade → usunięcie raty
  // (lub cofnięcie odhaczenia) kasuje powiązany deposit. source = z modułu Sprzedaż.
  contractPaymentId String?          @unique
  contractPayment   ContractPayment? @relation(fields: [contractPaymentId], references: [id], onDelete: Cascade)
  source         String   @default("MANUAL") // MANUAL | SALES (auto z harmonogramu)
  note           String?
  createdAt      DateTime @default(now())

  @@index([accountId])
  @@index([date])
  @@index([unitId])
}

// Uwolnienie transzy z rachunku powierniczego na konto operacyjne MD.
// Realny wpływ gotówki — bank wypłaca po potwierdzeniu milestone'a.
model EscrowRelease {
  id        String   @id @default(cuid())
  accountId String
  account   EscrowAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date      DateTime
  amount    Float
  milestone String?  // np. "zakończenie stanu surowego zamkniętego"
  note      String?
  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([date])
}
