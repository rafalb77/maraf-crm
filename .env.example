# =============================================================
# MARAF CRM — przykładowa konfiguracja środowiska
# =============================================================
# Skopiuj ten plik do `.env` i uzupełnij wartościami.
# `.env` jest w .gitignore — NIGDY nie commituj go do repo.

# ─────────────────────────────────────────────────────────────
# BAZA DANYCH PostgreSQL
# ─────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname?schema=public
#
# LOKALNIE (do wyboru):
#   a) Zainstaluj Postgres: https://www.postgresql.org/download/
#   b) Użyj cloud DB (free): https://neon.tech lub https://supabase.com
#
# PRODUKCJA (MyDevil):
#   Po stworzeniu bazy w panelu MyDevil dostaniesz gotowy URL.
DATABASE_URL="postgresql://user:password@localhost:5432/codecrm?schema=public"

# ─────────────────────────────────────────────────────────────
# NextAuth — uwierzytelnianie
# ─────────────────────────────────────────────────────────────
# Wygeneruj losowy 32+ znakowy sekret. Przykład w PowerShell:
#   [Convert]::ToBase64String((1..32 | %{Get-Random -Maximum 256}))
# albo na Linuxie / w git bash:
#   openssl rand -base64 32
NEXTAUTH_SECRET="zmien-to-na-bezpieczny-sekret-co-najmniej-32-znaki"

# Pełny URL aplikacji (BEZ slash na końcu)
#   Lokalnie:    http://localhost:3000
#   Produkcja:   https://twoja-domena.pl
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Pierwsze konto admina (używane przez `npm run db:seed`)
# Po pierwszym logowaniu od razu zmień hasło!
# ─────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@twojafirma.pl"
ADMIN_PASSWORD="zmien-natychmiast-po-pierwszym-logowaniu"

# ─────────────────────────────────────────────────────────────
# OPCJONALNE — Anthropic API (analiza AI rysunków DXF/PDF)
# ─────────────────────────────────────────────────────────────
# Niewymagane jeśli nie używasz modułu Drawings.
# ANTHROPIC_API_KEY="sk-ant-..."

# ─────────────────────────────────────────────────────────────
# OPCJONALNE — konwerter ODA (DXF/DWG → format)
# ─────────────────────────────────────────────────────────────
# Niewymagane jeśli nie używasz modułu Drawings.
# Lokalnie na Windows:
# ODA_CONVERTER_PATH="C:\Program Files\ODA\ODAFileConverter 27.1.0\ODAFileConverter.exe"

# ─────────────────────────────────────────────────────────────
# UWAGA:
# - SMTP konfigurowany jest przez panel /settings (nie zmienne env)
# - Google Calendar OAuth (token) zapisywany w bazie, nie w env
# ─────────────────────────────────────────────────────────────
